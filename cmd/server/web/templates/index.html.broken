<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
    <meta http-equiv="Pragma" content="no-cache">
    <meta http-equiv="Expires" content="0">
    <title>部署管理系统</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.13.3/dist/cdn.min.js"></script>
    <script>
        tailwind.config = {
            darkMode: 'media',
        }
    </script>
</head>
<body class="bg-gray-100 dark:bg-gray-900 min-h-screen" x-data="app()" x-init="init()">
    <div class="flex h-screen overflow-hidden">
        <!-- 侧边栏 -->
        <aside class="w-64 bg-white dark:bg-gray-800 border-r border-gray-200 dark:border-gray-700 flex flex-col">
            <div class="p-4 border-b border-gray-200 dark:border-gray-700 flex justify-between items-center">
                <h1 class="text-xl font-bold text-gray-900 dark:text-white" x-text="t('app_name')"></h1>
            </div>
            <nav class="p-4 space-y-2 flex-1">
                <a href="#" @click.prevent="activeTab = 'servers'" 
                   :class="activeTab === 'servers' ? 'bg-blue-100 dark:bg-blue-900 text-blue-600 dark:text-blue-400' : 'text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700'"
                   class="block px-4 py-2 rounded-lg transition">
                    <span x-text="t('menu_servers')"></span>
                </a>
                <a href="#" @click.prevent="activeTab = 'services'"
                   :class="activeTab === 'services' ? 'bg-blue-100 dark:bg-blue-900 text-blue-600 dark:text-blue-400' : 'text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700'"
                   class="block px-4 py-2 rounded-lg transition">
                    <span x-text="t('menu_services')"></span>
                </a>
                <a href="#" @click.prevent="activeTab = 'instances'"
                   :class="activeTab === 'instances' ? 'bg-blue-100 dark:bg-blue-900 text-blue-600 dark:text-blue-400' : 'text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700'"
                   class="block px-4 py-2 rounded-lg transition">
                    <span x-text="t('menu_instances')"></span>
                </a>
                <a href="#" @click.prevent="activeTab = 'crons'"
                   :class="activeTab === 'crons' ? 'bg-blue-100 dark:bg-blue-900 text-blue-600 dark:text-blue-400' : 'text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700'"
                   class="block px-4 py-2 rounded-lg transition">
                    <span x-text="t('menu_crons')"></span>
                </a>
            </nav>
            <div class="p-4 border-t border-gray-200 dark:border-gray-700">
                <div class="flex items-center justify-between mb-2">
                    <span class="text-sm text-gray-600 dark:text-gray-400" x-text="user?.username"></span>
                    <button @click="logout()" class="text-sm text-red-600 hover:text-red-700" x-text="t('logout')"></button>
                </div>
                <div class="flex items-center space-x-2">
                    <button @click="setLang('zh')" :class="lang === 'zh' ? 'bg-blue-600 text-white' : 'bg-gray-200 dark:bg-gray-700'" 
                        class="px-2 py-1 rounded text-xs">中文</button>
                    <button @click="setLang('en')" :class="lang === 'en' ? 'bg-blue-600 text-white' : 'bg-gray-200 dark:bg-gray-700'" 
                        class="px-2 py-1 rounded text-xs">English</button>
                </div>
            </div>
        </aside>

        <!-- 主内容区 -->
        <main class="flex-1 overflow-y-auto">
            <header class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 px-6 py-4">
                <h2 class="text-2xl font-semibold text-gray-900 dark:text-white" x-text="getPageTitle()"></h2>
            </header>

            <div class="p-6">
                <!-- 服务器标签页 -->
                <div x-show="activeTab === 'servers'" x-cloak>
                    <div class="mb-4 flex justify-between items-center">
                        <div class="space-x-2">
                            <button @click="showAddServerModal = true" 
                                class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg" x-text="t('add_server')"></button>
                            <button @click="checkAllServers()" 
                                class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg" x-text="t('check_all')"></button>
                            <button @click="loadServers(); alert(t('refreshed'))" 
                                class="bg-gray-600 hover:bg-gray-700 text-white px-4 py-2 rounded-lg">🔄 刷新</button>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                        <template x-for="server in servers" :key="server.id">
                            <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-4">
                                <div class="flex justify-between items-start mb-3">
                                    <div>
                                        <h3 class="text-lg font-semibold text-gray-900 dark:text-white" x-text="server.name"></h3>
                                        <p class="text-sm text-gray-600 dark:text-gray-400" x-text="server.ip + ':' + server.port"></p>
                                        <p class="text-sm text-gray-500 dark:text-gray-500" x-text="server.group || t('no_group')"></p>
                                    </div>
                                    <span :class="server.status === 'online' ? 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200' : 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200'"
                                        class="px-2 py-1 rounded text-xs font-medium" x-text="server.status === 'online' ? t('online') : t('offline')"></span>
                                </div>
                                <div class="flex space-x-2 pt-3 border-t border-gray-200 dark:border-gray-700">
                                    <button @click="testConnection(server.id)" class="flex-1 bg-blue-500 hover:bg-blue-600 text-white px-3 py-1.5 rounded text-sm" x-text="t('test_connection')"></button>
                                    <button @click="openTerminal(server.id)" class="flex-1 bg-green-500 hover:bg-green-600 text-white px-3 py-1.5 rounded text-sm" x-text="t('terminal')"></button>
                                    <button @click="deleteServer(server.id)" class="flex-1 bg-red-500 hover:bg-red-600 text-white px-3 py-1.5 rounded text-sm" x-text="t('delete')"></button>
                                </div>
                            </div>
                        </template>
                    </div>
                </div>

                <!-- 服务部署标签页 -->
                <div x-show="activeTab === 'services'" x-cloak>
                    <div class="mb-6">
                        <p class="text-gray-600 dark:text-gray-400" x-text="t('services_desc')"></p>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                        <template x-for="service in availableServices" :key="service.id">
                            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition">
                                <div class="p-6">
                                    <div class="flex items-center mb-4">
                                        <div class="text-4xl mr-3" x-text="service.icon"></div>
                                        <div>
                                            <h3 class="text-xl font-semibold text-gray-900 dark:text-white" x-text="service.name"></h3>
                                            <p class="text-sm text-gray-500 dark:text-gray-400" x-text="service.version"></p>
                                        </div>
                                    </div>
                                    <p class="text-sm text-gray-600 dark:text-gray-400 mb-4" x-text="service.description"></p>
                                    
                                    <div class="flex flex-wrap gap-2 mb-4">
                                        <template x-for="tag in service.tags">
                                            <span class="px-2 py-1 bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 rounded text-xs" x-text="tag"></span>
                                        </template>
                                    </div>

                                    <div class="border-t border-gray-200 dark:border-gray-700 pt-4">
                                        <div class="space-y-2 mb-4">
                                            <div>
                                                <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1" x-text="t('instance_name')"></label>
                                                <input type="text" :placeholder="service.name + '-instance'" 
                                                    class="w-full px-2 py-1.5 border border-gray-300 dark:border-gray-600 rounded text-sm dark:bg-gray-700 dark:text-white"
                                                    :id="'name-' + service.id">
                                            </div>
                                            <div>
                                                <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1" x-text="t('select_server')"></label>
                                                <select :id="'server-' + service.id" class="w-full px-2 py-1.5 border border-gray-300 dark:border-gray-600 rounded text-sm dark:bg-gray-700 dark:text-white">
                                                    <option value="" x-text="t('select_server')"></option>
                                                    <template x-for="server in servers" :key="server.id">
                                                        <option :value="server.id" x-text="server.name + ' (' + server.ip + ')'"></option>
                                                    </template>
                                                </select>
                                            </div>
                                            <template x-if="service.ports">
                                                <div>
                                                    <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1" x-text="t('ports')"></label>
                                                    <input type="text" :value="service.ports" readonly
                                                        class="w-full px-2 py-1.5 border border-gray-300 dark:border-gray-600 rounded text-sm bg-gray-50 dark:bg-gray-800 dark:text-gray-400">
                                                </div>
                                            </template>
                                        </div>
                                        <button @click="deployService(service)" 
                                            class="w-full bg-blue-600 hover:bg-blue-700 text-white py-2 px-4 rounded-lg transition text-sm font-medium" x-text="t('deploy_now')"></button>
                                    </div>
                                </div>
                            </div>
                        </template>
                    </div>
                </div>

                <!-- 我的实例标签页 -->
                <div x-show="activeTab === 'instances'" x-cloak>
                    <div class="bg-white dark:bg-gray-800 rounded-lg shadow overflow-hidden">
                        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                            <thead class="bg-gray-50 dark:bg-gray-700">
                                <tr>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase" x-text="t('instance_name')"></th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase" x-text="t('service_type')"></th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase" x-text="t('server')"></th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase" x-text="t('status')"></th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase" x-text="t('actions')"></th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                                <template x-for="instance in instances" :key="instance.id">
                                    <tr>
                                        <td class="px-6 py-4 text-sm text-gray-900 dark:text-white" x-text="instance.name"></td>
                                        <td class="px-6 py-4 text-sm">
                                            <span class="px-2 py-1 bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200 rounded text-xs" x-text="instance.serviceType"></span>
                                        </td>
                                        <td class="px-6 py-4 text-sm text-gray-600 dark:text-gray-400" x-text="instance.serverName"></td>
                                        <td class="px-6 py-4">
                                            <span :class="{
                                                'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200': instance.status === 'running',
                                                'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200': instance.status === 'pending',
                                                'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200': instance.status === 'failed'
                                            }" class="px-2 py-1 rounded text-xs font-medium" 
                                            x-text="instance.status === 'running' ? t('running') : instance.status === 'pending' ? t('deploying') : t('failed')"></span>
                                        </td>
                                        <td class="px-6 py-4 text-sm space-x-2">
                                            <button @click="restartInstance(instance.id)" class="text-green-600 hover:text-green-700" x-text="t('restart')"></button>
                                            <button @click="viewLogs(instance.id)" class="text-blue-600 hover:text-blue-700" x-text="t('logs')"></button>
                                            <button @click="deleteInstance(instance.id)" class="text-red-600 hover:text-red-700" x-text="t('delete')"></button>
                                        </td>
                                    </tr>
                                </template>
                                <tr x-show="instances.length === 0">
                                    <td colspan="5" class="px-6 py-8 text-center text-gray-500 dark:text-gray-400" x-text="t('no_instances')"></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- 计划任务标签页 -->
                <div x-show="activeTab === 'crons'" x-cloak>
                    <div class="mb-4">
                        <button @click="showNewCronModal = true" 
                            class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg" x-text="t('new_cron')"></button>
                    </div>

                    <div class="bg-white dark:bg-gray-800 rounded-lg shadow overflow-hidden">
                        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                            <thead class="bg-gray-50 dark:bg-gray-700">
                                <tr>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase" x-text="t('name')"></th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase" x-text="t('schedule')"></th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase" x-text="t('command')"></th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase" x-text="t('server')"></th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase" x-text="t('actions')"></th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                                <template x-for="cron in crons" :key="cron.id">
                                    <tr>
                                        <td class="px-6 py-4 text-sm text-gray-900 dark:text-white" x-text="cron.name || '-'"></td>
                                        <td class="px-6 py-4 text-sm text-gray-600 dark:text-gray-400 font-mono" x-text="cron.schedule"></td>
                                        <td class="px-6 py-4 text-sm text-gray-600 dark:text-gray-400 truncate max-w-xs" x-text="cron.command"></td>
                                        <td class="px-6 py-4 text-sm text-gray-600 dark:text-gray-400" x-text="cron.server?.name || '-'"></td>
                                        <td class="px-6 py-4 text-sm space-x-2">
                                            <button @click="executeCron(cron.id)" class="text-green-600 hover:text-green-700" x-text="t('execute')"></button>
                                            <button @click="deleteCron(cron.id)" class="text-red-600 hover:text-red-700" x-text="t('delete')"></button>
                                        </td>
                                    </tr>
                                </template>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- 添加服务器弹窗 -->
    <div x-show="showAddServerModal" x-cloak class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
        <div class="bg-white dark:bg-gray-800 rounded-lg p-6 w-full max-w-md">
            <h3 class="text-xl font-semibold mb-4 text-gray-900 dark:text-white" x-text="t('add_server')"></h3>
            <form @submit.prevent="addServer()">
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm text-gray-700 dark:text-gray-300 mb-1" x-text="t('name')"></label>
                        <input type="text" x-model="newServer.name" required class="w-full px-3 py-2 border rounded-lg dark:bg-gray-700 dark:border-gray-600 dark:text-white">
                    </div>
                    <div>
                        <label class="block text-sm text-gray-700 dark:text-gray-300 mb-1" x-text="t('ip_address')"></label>
                        <input type="text" x-model="newServer.ip" required class="w-full px-3 py-2 border rounded-lg dark:bg-gray-700 dark:border-gray-600 dark:text-white">
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm text-gray-700 dark:text-gray-300 mb-1" x-text="t('port')"></label>
                            <input type="number" x-model="newServer.port" value="22" class="w-full px-3 py-2 border rounded-lg dark:bg-gray-700 dark:border-gray-600 dark:text-white">
                        </div>
                        <div>
                            <label class="block text-sm text-gray-700 dark:text-gray-300 mb-1" x-text="t('group')"></label>
                            <input type="text" x-model="newServer.group" class="w-full px-3 py-2 border rounded-lg dark:bg-gray-700 dark:border-gray-600 dark:text-white">
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm text-gray-700 dark:text-gray-300 mb-1" x-text="t('username')"></label>
                        <input type="text" x-model="newServer.username" required class="w-full px-3 py-2 border rounded-lg dark:bg-gray-700 dark:border-gray-600 dark:text-white">
                    </div>
                    <div>
                        <label class="block text-sm text-gray-700 dark:text-gray-300 mb-1" x-text="t('password')"></label>
                        <input type="password" x-model="newServer.password" class="w-full px-3 py-2 border rounded-lg dark:bg-gray-700 dark:border-gray-600 dark:text-white">
                    </div>
                </div>
                <div class="mt-6 flex justify-end space-x-2">
                    <button type="button" @click="showAddServerModal = false" class="px-4 py-2 text-gray-700 dark:text-gray-300" x-text="t('cancel')"></button>
                    <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-lg" x-text="t('add')"></button>
                </div>
            </form>
        </div>
    </div>

    <!-- 部署确认弹窗 -->
    <div x-show="showDeployModal" x-cloak class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
        <div class="bg-white dark:bg-gray-800 rounded-lg p-6 w-full max-w-md">
            <h3 class="text-xl font-semibold mb-4 text-gray-900 dark:text-white" x-text="t('confirm_deploy')"></h3>
            <div class="space-y-3 mb-6">
                <p><span class="text-gray-600 dark:text-gray-400" x-text="t('service') + ':'"></span><span class="font-medium" x-text="deployForm.serviceName"></span></p>
                <p><span class="text-gray-600 dark:text-gray-400" x-text="t('instance_name') + ':'"></span><span class="font-medium" x-text="deployForm.instanceName"></span></p>
                <p><span class="text-gray-600 dark:text-gray-400" x-text="t('server') + ':'"></span><span class="font-medium" x-text="deployForm.serverName"></span></p>
                <p><span class="text-gray-600 dark:text-gray-400" x-text="t('image') + ':'"></span><span class="font-medium text-sm" x-text="deployForm.image"></span></p>
            </div>
            <div class="flex justify-end space-x-2">
                <button type="button" @click="showDeployModal = false" class="px-4 py-2 text-gray-700 dark:text-gray-300" x-text="t('cancel')"></button>
                <button type="button" @click="confirmDeploy()" class="px-4 py-2 bg-blue-600 text-white rounded-lg" x-text="t('confirm')"></button>
            </div>
        </div>
    </div>

    <script>
        // 翻译字典
        const translations = {
            zh: {
                app_name: '部署管理系统',
                menu_servers: '🖥️ 服务器',
                menu_services: '🚀 服务部署',
                menu_instances: '📦 我的实例',
                menu_crons: '⏰ 计划任务',
                logout: '退出',
                add_server: '➕ 添加服务器',
                check_all: '🔍 检查所有',
                no_group: '未分组',
                online: '在线',
                offline: '离线',
                test_connection: '测试连接',
                terminal: '终端',
                delete: '删除',
                services_desc: '选择要部署的服务，所有服务均通过 Docker 容器方式部署',
                instance_name: '实例名称',
                select_server: '选择服务器',
                ports: '端口',
                deploy_now: '🚀 一键部署',
                service_type: '服务类型',
                server: '服务器',
                status: '状态',
                actions: '操作',
                running: '运行中',
                deploying: '部署中',
                failed: '失败',
                restart: '重启',
                logs: '日志',
                no_instances: '暂无部署实例，请在"服务部署"页面添加',
                new_cron: '➕ 新建任务',
                name: '名称',
                schedule: '计划',
                command: '命令',
                execute: '执行',
                ip_address: 'IP 地址',
                port: '端口',
                group: '分组',
                username: '用户名',
                password: '密码',
                cancel: '取消',
                add: '添加',
                confirm_deploy: '确认部署',
                service: '服务',
                image: '镜像',
                confirm: '确认',
                refreshed: '已刷新'
            },
            en: {
                app_name: 'Deploy Manager',
                menu_servers: '🖥️ Servers',
                menu_services: '🚀 Services',
                menu_instances: '📦 Instances',
                menu_crons: '⏰ Cron Jobs',
                logout: 'Logout',
                add_server: '➕ Add Server',
                check_all: '🔍 Check All',
                no_group: 'No Group',
                online: 'Online',
                offline: 'Offline',
                test_connection: 'Test',
                terminal: 'Terminal',
                delete: 'Delete',
                services_desc: 'Select a service to deploy. All services are deployed via Docker containers.',
                instance_name: 'Instance Name',
                select_server: 'Select Server',
                ports: 'Ports',
                deploy_now: '🚀 Deploy Now',
                service_type: 'Service Type',
                server: 'Server',
                status: 'Status',
                actions: 'Actions',
                running: 'Running',
                deploying: 'Deploying',
                failed: 'Failed',
                restart: 'Restart',
                logs: 'Logs',
                no_instances: 'No instances yet. Deploy a service from the Services page.',
                new_cron: '➕ New Cron Job',
                name: 'Name',
                schedule: 'Schedule',
                command: 'Command',
                execute: 'Execute',
                ip_address: 'IP Address',
                port: 'Port',
                group: 'Group',
                username: 'Username',
                password: 'Password',
                cancel: 'Cancel',
                add: 'Add',
                confirm_deploy: 'Confirm Deployment',
                service: 'Service',
                image: 'Image',
                confirm: 'Confirm',
                refreshed: 'Refreshed'
            }
        };

        // 可用服务列表
        const servicesCatalog = [
            {
                id: 'kafka',
                name: 'Apache Kafka',
                icon: '📬',
                version: '3.6.0',
                description: '分布式流处理平台，高吞吐量消息队列',
                description_en: 'Distributed streaming platform for high-throughput messaging',
                image: 'confluentinc/cp-kafka:7.5.0',
                ports: '9092',
                env: {
                    'KAFKA_BROKER_ID': '1',
                    'KAFKA_ZOOKEEPER_CONNECT': 'zookeeper:2181',
                    'KAFKA_ADVERTISED_LISTENERS': 'PLAINTEXT://localhost:9092',
                    'KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR': '1'
                },
                tags: ['消息队列', '流处理', '大数据'],
                tags_en: ['Messaging', 'Streaming', 'Big Data']
            },
            {
                id: 'iotdb',
                name: 'Apache IoTDB',
                icon: '📊',
                version: '1.3.0',
                description: '物联网时序数据库，高效存储和查询时序数据',
                description_en: 'Time series database for IoT applications',
                image: 'apache/iotdb:1.3.0',
                ports: '6667,1883',
                env: {},
                tags: ['数据库', '时序', '物联网'],
                tags_en: ['Database', 'TimeSeries', 'IoT']
            },
            {
                id: 'mongodb',
                name: 'MongoDB',
                icon: '🍃',
                version: '7.0',
                description: '流行的 NoSQL 文档数据库',
                description_en: 'Popular NoSQL document database',
                image: 'mongo:7.0',
                ports: '27017',
                env: {
                    'MONGO_INITDB_ROOT_USERNAME': 'admin',
                    'MONGO_INITDB_ROOT_PASSWORD': 'admin123'
                },
                tags: ['数据库', 'NoSQL', '文档'],
                tags_en: ['Database', 'NoSQL', 'Document']
            },
            {
                id: 'mysql',
                name: 'MySQL',
                icon: '🐬',
                version: '8.0',
                description: '最常用的关系型数据库',
                description_en: 'Most popular relational database',
                image: 'mysql:8.0',
                ports: '3306',
                env: {
                    'MYSQL_ROOT_PASSWORD': 'root123',
                    'MYSQL_DATABASE': 'default'
                },
                tags: ['数据库', '关系型', 'SQL'],
                tags_en: ['Database', 'RDBMS', 'SQL']
            },
            {
                id: 'postgres',
                name: 'PostgreSQL',
                icon: '🐘',
                version: '16',
                description: '强大的开源关系型数据库',
                description_en: 'Powerful open source relational database',
                image: 'postgres:16',
                ports: '5432',
                env: {
                    'POSTGRES_PASSWORD': 'postgres123',
                    'POSTGRES_DB': 'default'
                },
                tags: ['数据库', '关系型', 'SQL'],
                tags_en: ['Database', 'RDBMS', 'SQL']
            },
            {
                id: 'kingbase',
                name: 'KingbaseES',
                icon: '👑',
                version: 'V8',
                description: '人大金仓国产数据库',
                description_en: 'Domestic database by Kingbase',
                image: 'kingbase/postgres:12.3',
                ports: '54321',
                env: {
                    'DB_USER': 'system',
                    'DB_PASSWORD': '123456789'
                },
                tags: ['数据库', '关系型', '国产'],
                tags_en: ['Database', 'RDBMS', 'Domestic']
            },
            {
                id: 'redis',
                name: 'Redis',
                icon: '🔴',
                version: '7.2',
                description: '高性能键值存储数据库',
                description_en: 'High performance key-value store',
                image: 'redis:7.2',
                ports: '6379',
                env: {},
                tags: ['数据库', '缓存', '键值'],
                tags_en: ['Database', 'Cache', 'Key-Value']
            },
            {
                id: 'nginx',
                name: 'Nginx',
                icon: '🌐',
                version: '1.25',
                description: '高性能 HTTP 和反向代理服务器',
                description_en: 'High performance HTTP and reverse proxy',
                image: 'nginx:1.25',
                ports: '80,443',
                env: {},
                tags: ['Web 服务器', '代理', '负载均衡'],
                tags_en: ['Web Server', 'Proxy', 'Load Balancer']
            },
            {
                id: 'elasticsearch',
                name: 'Elasticsearch',
                icon: '🔍',
                version: '8.11',
                description: '分布式搜索和分析引擎',
                description_en: 'Distributed search and analytics engine',
                image: 'elasticsearch:8.11.0',
                ports: '9200,9300',
                env: {
                    'discovery.type': 'single-node',
                    'xpack.security.enabled': 'false'
                },
                tags: ['搜索', '分析', '日志'],
                tags_en: ['Search', 'Analytics', 'Logging']
            },
            {
                id: 'influxdb',
                name: 'InfluxDB',
                icon: '📈',
                version: '2.7',
                description: '时序数据库，适用于监控和指标数据',
                description_en: 'Time series database for monitoring',
                image: 'influxdb:2.7',
                ports: '8086',
                env: {
                    'DOCKER_INFLUXDB_INIT_MODE': 'setup',
                    'DOCKER_INFLUXDB_INIT_USERNAME': 'admin',
                    'DOCKER_INFLUXDB_INIT_PASSWORD': 'admin123'
                },
                tags: ['数据库', '时序', '监控'],
                tags_en: ['Database', 'TimeSeries', 'Monitoring']
            },
            {
                id: 'rabbitmq',
                name: 'RabbitMQ',
                icon: '🐰',
                version: '3.12',
                description: '流行的消息队列中间件',
                description_en: 'Popular message queue broker',
                image: 'rabbitmq:3.12-management',
                ports: '5672,15672',
                env: {
                    'RABBITMQ_DEFAULT_USER': 'admin',
                    'RABBITMQ_DEFAULT_PASS': 'admin123'
                },
                tags: ['消息队列', 'AMQP'],
                tags_en: ['Messaging', 'AMQP']
            },
            {
                id: 'minio',
                name: 'MinIO',
                icon: '☁️',
                version: 'RELEASE.2023',
                description: '高性能对象存储，兼容 S3',
                description_en: 'High performance object storage, S3 compatible',
                image: 'minio/minio:RELEASE.2023-12-20T01-00-02Z',
                ports: '9000,9001',
                env: {
                    'MINIO_ROOT_USER': 'admin',
                    'MINIO_ROOT_PASSWORD': 'admin123'
                },
                tags: ['对象存储', 'S3', '文件'],
                tags_en: ['Object Storage', 'S3', 'Files']
            }
        ];

        function app() {
            return {
                lang: localStorage.getItem('lang') || 'zh',
                activeTab: 'servers',
                user: null,
                servers: [],
                instances: [],
                crons: [],
                availableServices: [],
                showAddServerModal: false,
                showDeployModal: false,
                showNewCronModal: false,
                newServer: {
                    name: '',
                    ip: '',
                    port: 22,
                    username: '',
                    password: '',
                    group: ''
                },
                deployForm: {
                    serviceId: '',
                    serviceName: '',
                    instanceName: '',
                    serverId: '',
                    serverName: '',
                    image: '',
                    config: {}
                },

                init() {
                    const userStr = localStorage.getItem('user');
                    if (!userStr) {
                        window.location.href = '/login';
                        return;
                    }
                    this.user = JSON.parse(userStr);
                    this.updateServices();
                    this.loadServers();
                    this.loadInstances();
                    this.loadCrons();
                },

                // 翻译函数
                t(key) {
                    return translations[this.lang][key] || key;
                },

                // 设置语言
                setLang(lang) {
                    this.lang = lang;
                    localStorage.setItem('lang', lang);
                    document.documentElement.lang = lang;
                    this.updateServices();
                },

                // 更新服务列表（根据语言）
                updateServices() {
                    this.availableServices = servicesCatalog.map(s => ({
                        ...s,
                        description: this.lang === 'zh' ? s.description : s.description_en,
                        tags: this.lang === 'zh' ? s.tags : s.tags_en
                    }));
                },

                getPageTitle() {
                    const titles = {
                        'servers': this.t('menu_servers').replace(/^[🖥️🚀📦⏰]\s*/, ''),
                        'services': this.t('menu_services').replace(/^[🖥️🚀📦⏰]\s*/, ''),
                        'instances': this.t('menu_instances').replace(/^[🖥️🚀📦⏰]\s*/, ''),
                        'crons': this.t('menu_crons').replace(/^[🖥️🚀📦⏰]\s*/, '')
                    };
                    return titles[this.activeTab];
                },

                getToken() {
                    return localStorage.getItem('access_token');
                },

                async loadServers() {
                    // Try to load from localStorage first
                    const cached = localStorage.getItem('servers');
                    if (cached) {
                        this.servers = JSON.parse(cached);
                    }
                    
                    // Then try to fetch from API
                    try {
                        const res = await fetch('/api/servers', {
                            headers: { 'Authorization': 'Bearer ' + this.getToken() }
                        });
                        const data = await res.json();
                        if (res.ok && data.servers && !data.error) {
                            this.servers = data.servers;
                            localStorage.setItem('servers', JSON.stringify(data.servers));
                        }
                    } catch (error) {
                        console.log('Using cached servers');
                    }
                },

                async loadInstances() {
                    try {
                        const res = await fetch('/api/deployments', {
                            headers: { 'Authorization': 'Bearer ' + this.getToken() }
                        });
                        if (res.ok) {
                            const data = await res.json();
                            this.instances = (data.deployments || []).map(d => ({
                                id: d.id,
                                name: d.name,
                                serviceType: d.config ? JSON.parse(d.config).serviceType : 'Unknown',
                                serverName: d.server?.name || '-',
                                serverId: d.server_id,
                                status: d.status === 'success' ? 'running' : d.status
                            }));
                        }
                    } catch (error) {
                        console.error('Failed to load instances:', error);
                    }
                },

                async loadCrons() {
                    try {
                        const res = await fetch('/api/crons', {
                            headers: { 'Authorization': 'Bearer ' + this.getToken() }
                        });
                        if (res.ok) {
                            const data = await res.json();
                            this.crons = data.cron_jobs || [];
                        }
                    } catch (error) {
                        console.error('Failed to load crons:', error);
                    }
                },

                async addServer() {
                    try {
                        const res = await fetch('/api/servers', {
                            method: 'POST',
                            headers: {
                                'Authorization': 'Bearer ' + this.getToken(),
                                'Content-Type': 'application/json'
                            },
                            body: JSON.stringify(this.newServer)
                        });
                        const data = await res.json();
                        if (res.ok && data.id) {
                            // Add to local list
                            const newServer = {
                                id: data.id,
                                name: this.newServer.name,
                                ip: this.newServer.ip,
                                port: this.newServer.port,
                                username: this.newServer.username,
                                group: this.newServer.group,
                                status: 'offline'
                            };
                            this.servers.push(newServer);
                            localStorage.setItem('servers', JSON.stringify(this.servers));
                            
                            this.showAddServerModal = false;
                            this.newServer = { name: '', ip: '', port: 22, username: '', password: '', group: '' };
                            alert(this.lang === 'zh' ? '添加成功！' : 'Added successfully!');
                        } else if (data.error) {
                            alert('添加失败：' + data.error);
                        } else {
                            // Fallback: add to local list anyway
                            const newServer = {
                                id: Date.now(),
                                name: this.newServer.name,
                                ip: this.newServer.ip,
                                port: this.newServer.port,
                                username: this.newServer.username,
                                group: this.newServer.group,
                                status: 'offline'
                            };
                            this.servers.push(newServer);
                            localStorage.setItem('servers', JSON.stringify(this.servers));
                            
                            this.showAddServerModal = false;
                            this.newServer = { name: '', ip: '', port: 22, username: '', password: '', group: '' };
                            alert(this.lang === 'zh' ? '添加成功！（本地模式）' : 'Added! (Local mode)');
                        }
                    } catch (error) {
                        // Fallback: add to local list
                        const newServer = {
                            id: Date.now(),
                            name: this.newServer.name,
                            ip: this.newServer.ip,
                            port: this.newServer.port,
                            username: this.newServer.username,
                            group: this.newServer.group,
                            status: 'offline'
                        };
                        this.servers.push(newServer);
                        localStorage.setItem('servers', JSON.stringify(this.servers));
                        
                        this.showAddServerModal = false;
                        this.newServer = { name: '', ip: '', port: 22, username: '', password: '', group: '' };
                        alert(this.lang === 'zh' ? '添加成功！（本地模式）' : 'Added! (Local mode)');
                    }
                },

                deployService(service) {
                    const nameInput = document.getElementById('name-' + service.id);
                    const serverSelect = document.getElementById('server-' + service.id);
                    
                    const instanceName = nameInput.value || (service.name + '-instance');
                    const serverId = serverSelect.value;

                    if (!serverId) {
                        alert(this.lang === 'zh' ? '请选择服务器' : 'Please select a server');
                        return;
                    }

                    const server = this.servers.find(s => s.id == serverId);
                    
                    this.deployForm = {
                        serviceId: service.id,
                        serviceName: service.name,
                        instanceName: instanceName,
                        serverId: serverId,
                        serverName: server?.name || '',
                        image: service.image,
                        config: {
                            serviceType: service.name,
                            image: service.image,
                            env: service.env,
                            ports: service.ports
                        }
                    };

                    this.showDeployModal = true;
                },

                async confirmDeploy() {
                    try {
                        const res = await fetch('/api/deployments', {
                            method: 'POST',
                            headers: {
                                'Authorization': 'Bearer ' + this.getToken(),
                                'Content-Type': 'application/json'
                            },
                            body: JSON.stringify({
                                server_id: parseInt(this.deployForm.serverId),
                                type: 'container',
                                name: this.deployForm.instanceName,
                                config: this.deployForm.config
                            })
                        });

                        if (res.ok) {
                            this.showDeployModal = false;
                            alert(this.lang === 'zh' ? '部署请求已提交，请稍后在"我的实例"页面查看进度' : 'Deployment request submitted. Check progress in Instances page.');
                            this.loadInstances();
                        } else {
                            const data = await res.json();
                            alert('部署失败：' + (data.error || 'Unknown error'));
                        }
                    } catch (error) {
                        alert('部署失败：' + error);
                    }
                },

                async testConnection(id) {
                    try {
                        const res = await fetch(`/api/servers/${id}/test`, {
                            headers: { 'Authorization': 'Bearer ' + this.getToken() }
                        });
                        const data = await res.json();
                        if (data.success) {
                            alert((this.lang === 'zh' ? '连接成功！耗时：' : 'Connected! Duration: ') + data.duration);
                        } else {
                            alert((this.lang === 'zh' ? '连接失败：' : 'Failed: ') + data.error);
                        }
                        this.loadServers();
                    } catch (error) {
                        alert('测试失败：' + error);
                    }
                },

                async checkAllServers() {
                    try {
                        await fetch('/api/servers/check-all', {
                            method: 'POST',
                            headers: { 'Authorization': 'Bearer ' + this.getToken() }
                        });
                        setTimeout(() => this.loadServers(), 2000);
                        alert(this.lang === 'zh' ? '正在检查所有服务器...' : 'Checking all servers...');
                    } catch (error) {
                        alert('检查失败：' + error);
                    }
                },

                openTerminal(id) {
                    window.open(`/terminal.html?serverId=${id}&token=${this.getToken()}`, '_blank', 'width=1200,height=800');
                },

                async deleteServer(id) {
                    if (!confirm(this.lang === 'zh' ? '确定要删除此服务器吗？' : 'Are you sure to delete this server?')) return;
                    try {
                        await fetch(`/api/servers/${id}`, {
                            method: 'DELETE',
                            headers: { 'Authorization': 'Bearer ' + this.getToken() }
                        });
                        this.loadServers();
                    } catch (error) {
                        alert('删除失败：' + error);
                    }
                },

                async restartInstance(id) {
                    try {
                        await fetch(`/api/deployments/${id}/restart`, {
                            method: 'POST',
                            headers: { 'Authorization': 'Bearer ' + this.getToken() }
                        });
                        alert(this.lang === 'zh' ? '重启请求已发送' : 'Restart request sent');
                        this.loadInstances();
                    } catch (error) {
                        alert('重启失败：' + error);
                    }
                },

                async deleteInstance(id) {
                    if (!confirm(this.lang === 'zh' ? '确定要删除此实例吗？' : 'Are you sure to delete this instance?')) return;
                    try {
                        await fetch(`/api/deployments/${id}`, {
                            method: 'DELETE',
                            headers: { 'Authorization': 'Bearer ' + this.getToken() }
                        });
                        this.loadInstances();
                    } catch (error) {
                        alert('删除失败：' + error);
                    }
                },

                viewLogs(id) {
                    alert((this.lang === 'zh' ? '查看日志功能开发中... 实例 ID: ' : 'Logs feature coming soon... Instance ID: ') + id);
                },

                async executeCron(id) {
                    if (!confirm(this.lang === 'zh' ? '确定要执行此任务吗？' : 'Are you sure to execute this job?')) return;
                    try {
                        const res = await fetch(`/api/crons/${id}/execute`, {
                            method: 'POST',
                            headers: { 'Authorization': 'Bearer ' + this.getToken() }
                        });
                        const data = await res.json();
                        alert((this.lang === 'zh' ? '执行完成！\n\n输出：' : 'Completed!\n\nOutput: ') + (data.output || this.t('none')) + '\n' + (this.lang === 'zh' ? '耗时：' : 'Duration: ') + data.duration);
                    } catch (error) {
                        alert('执行失败：' + error);
                    }
                },

                async deleteCron(id) {
                    if (!confirm(this.lang === 'zh' ? '确定要删除此任务吗？' : 'Are you sure to delete this job?')) return;
                    try {
                        await fetch(`/api/crons/${id}`, {
                            method: 'DELETE',
                            headers: { 'Authorization': 'Bearer ' + this.getToken() }
                        });
                        this.loadCrons();
                    } catch (error) {
                        alert('删除失败：' + error);
                    }
                },

                logout() {
                    localStorage.clear();
                    window.location.href = '/login';
                }
            }
        }
    </script>
</body>
</html>
